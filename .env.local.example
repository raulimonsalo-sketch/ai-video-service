# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get from https://dashboard.stripe.com/webhooks  (add endpoint: /api/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Kling AI ──────────────────────────────────────────────────────────────────
# Get from https://klingai.com/dev (API Access section)
KLING_ACCESS_KEY=your_access_key_here
KLING_SECRET_KEY=your_secret_key_here

# ── Resend (email) ────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...
# Must be a verified sender domain in Resend
EMAIL_FROM=AI Media Studio <orders@yourdomain.com>

# ── App URL ───────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash). Used for Stripe redirect + Kling callback.
# Set this in Vercel Environment Variables after first deploy.
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
